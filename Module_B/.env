MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=akash
MYSQL_DATABASE=outlet_management

# Assignment 4 sharding settings (opt-in)
MYSQL_ENABLE_SHARDING=true
MYSQL_SHARD_COUNT=3
MYSQL_PRIMARY_SHARD=0
MYSQL_SHARDED_TABLES=customers,sales,sale_items,payments
MYSQL_SHARD_TABLE_TEMPLATE=shard_{shard_id}_{table}

# Shard index mapping used in code:
# shard_id=0 -> Shard 1, shard_id=1 -> Shard 2, shard_id=2 -> Shard 3

# Database shard node connection defaults (update as needed)
MYSQL_SHARD_0_HOST=10.0.116.184
